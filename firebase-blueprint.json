{
  "entities": {
    "User": {
      "title": "User",
      "description": "Core user profile for authentication and role management",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "parent", "tutor"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Tutor": {
      "title": "Tutor",
      "description": "Detailed tutor profile and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "location": { "type": "string" },
        "availability": { "type": "object" },
        "experience": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female"] },
        "pricing": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "bio": { "type": "string" }
      },
      "required": ["uid", "subjects", "location", "status"]
    },
    "Parent": {
      "title": "Parent",
      "description": "Parent specific contact information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["uid", "phone"]
    },
    "Request": {
      "title": "Tutor Request",
      "description": "A request for a tutor submitted by a parent",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "parentId": { "type": "string" },
        "studentName": { "type": "string" },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "location": { "type": "string" },
        "availability": { "type": "object" },
        "genderPreference": { "type": "string" },
        "budget": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "matching", "assigned", "completed"] },
        "matchedTutorId": { "type": "string" },
        "suggestedTutorIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["parentId", "studentName", "subjects", "status"]
    },
    "Session": {
      "title": "Tutoring Session",
      "description": "A scheduled tutoring session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "requestId": { "type": "string" },
        "tutorId": { "type": "string" },
        "parentId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled"] },
        "notes": { "type": "string" }
      },
      "required": ["requestId", "tutorId", "parentId", "startTime", "endTime", "status"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A payment record from a parent",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "parentId": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "paid"] },
        "type": { "type": "string", "enum": ["tuition", "registration"] },
        "requestId": { "type": "string" }
      },
      "required": ["parentId", "amount", "date", "status", "type"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A system notification for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "link": { "type": "string" }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/tutors/{uid}": { "schema": "Tutor", "description": "Tutor details" },
    "/parents/{uid}": { "schema": "Parent", "description": "Parent details" },
    "/requests/{requestId}": { "schema": "Request", "description": "Tutor requests" },
    "/sessions/{sessionId}": { "schema": "Session", "description": "Tutoring sessions" },
    "/payments/{paymentId}": { "schema": "Payment", "description": "Payment records" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications" }
  }
}
